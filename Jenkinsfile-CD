pipeline {
    agent any

    environment {
        RESOURCE_GROUP = "rg-petclinic"
        AKS_CLUSTER = "aks-petclinic"
        NAMESPACE = "petclinic"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Connect to AKS') {
            steps {
                bat """
                az aks get-credentials ^
                --resource-group %RESOURCE_GROUP% ^
                --name %AKS_CLUSTER% ^
                --overwrite-existing
                """
            }
        }

        stage('Deploy to AKS') {
            steps {
                bat """
                kubectl apply -f k8s/namespace.yaml
                kubectl apply -f k8s/deployment.yaml
                kubectl apply -f k8s/service.yaml
                """
            }
        }

        stage('Restart Deployment') {
            steps {
                bat """
                kubectl rollout restart deployment/petclinic-app -n %NAMESPACE%
                """
            }
        }

        stage('Verify Deployment') {
            steps {
                bat """
                kubectl rollout status deployment/petclinic-app -n %NAMESPACE%
                kubectl get pods -n %NAMESPACE%
                kubectl get svc -n %NAMESPACE%
                """
            }
        }
    }

    post {
        success {
            echo 'CD Pipeline completed successfully. Application deployed to AKS.'
        }
        failure {
            echo 'CD Pipeline failed.'
        }
    }
}