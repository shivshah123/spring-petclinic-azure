pipeline {
    agent any

    environment {
        ACR_LOGIN_SERVER = "shivpetclinicacr2026.azurecr.io"
        IMAGE_NAME = "spring-petclinic"
        IMAGE_TAG = "latest"
        TRIVY_PATH = "C:\\Users\\vishv\\AppData\\Local\\Microsoft\\WinGet\\Packages\\AquaSecurity.Trivy_Microsoft.Winget.Source_8wekyb3d8bbwe\\trivy.exe"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                bat '.\\mvnw.cmd clean compile'
            }
        }

        stage('Unit Tests') {
            steps {
                bat '.\\mvnw.cmd test'
            }
        }

       stage('SonarQube Analysis') {
            steps {
             withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
             bat '.\\mvnw.cmd sonar:sonar -Dsonar.projectKey=spring-petclinic -Dsonar.projectName=spring-petclinic -Dsonar.host.url=http://localhost:9000 -Dsonar.token=%SONAR_TOKEN%'
            }
        }
    }

        stage('Package JAR') {
            steps {
                bat '.\\mvnw.cmd clean package -DskipTests'
            }
    }

        stage('Docker Build ARM64') {
            steps {
                bat """
                docker buildx build --platform linux/arm64 ^
                -t %ACR_LOGIN_SERVER%/%IMAGE_NAME%:%IMAGE_TAG% ^
                --load .
                """
            }
        }

        stage('Docker Login to ACR') {
            steps {
                bat 'az acr login --name shivpetclinicacr2026'
            }
        }

        stage('Trivy Scan') {
            steps {
                bat """
                "%TRIVY_PATH%" image --severity HIGH,CRITICAL --exit-code 0 ^
                %ACR_LOGIN_SERVER%/%IMAGE_NAME%:%IMAGE_TAG%
                """
            }
        }

        stage('Push Image to ACR') {
            steps {
                bat """
                docker buildx build --platform linux/arm64 ^
                -t %ACR_LOGIN_SERVER%/%IMAGE_NAME%:%IMAGE_TAG% ^
                --push .
                """
            }
        }
    }

    post {
        success {
            echo 'CI Pipeline completed successfully with SonarQube, Trivy, and ACR push.'
        }
        failure {
            echo 'CI Pipeline failed.'
        }
    }
}